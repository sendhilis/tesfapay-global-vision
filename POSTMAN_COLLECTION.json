{
	"info": {
		"_postman_id": "globalpay-api-v1",
		"name": "GlobalPay API v1.0",
		"description": "Complete REST API collection for GlobalPay mobile wallet backend.\n\nBase URL: {{baseUrl}}\nAuth: Bearer JWT in Authorization header\nCurrency: ETB (Ethiopian Birr)\n\nImport this collection and set the 'baseUrl' variable to your Spring Boot server (e.g., http://localhost:8080/v1).",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8080/v1",
			"type": "string"
		},
		{
			"key": "accessToken",
			"value": "",
			"type": "string"
		},
		{
			"key": "refreshToken",
			"value": "",
			"type": "string"
		},
		{
			"key": "userId",
			"value": "",
			"type": "string"
		},
		{
			"key": "testPhone",
			"value": "+251911234567",
			"type": "string"
		},
		{
			"key": "testPin",
			"value": "123456",
			"type": "string"
		}
	],
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{accessToken}}",
				"type": "string"
			}
		]
	},
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [""]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					"if (pm.response.code === 401) {",
					"    console.log('Auth token expired — re-run Login or Refresh Token request');",
					"}"
				]
			}
		}
	],
	"item": [
		{
			"name": "01 — Authentication",
			"description": "User registration, login, OTP verification, token refresh, and logout.",
			"item": [
				{
					"name": "Register User",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"url": {"raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"]},
						"body": {
							"mode": "raw",
							"raw": "{\n  \"phone\": \"{{testPhone}}\",\n  \"firstName\": \"Abebe\",\n  \"lastName\": \"Girma\",\n  \"pin\": \"{{testPin}}\"\n}"
						}
					},
					"event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
						"if (pm.response.code === 201) {",
						"    var json = pm.response.json();",
						"    pm.collectionVariables.set('userId', json.userId);",
						"    pm.test('User created', () => pm.expect(json.otpSent).to.be.true);",
						"}"
					]}}]
				},
				{
					"name": "Verify OTP",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"url": {"raw": "{{baseUrl}}/auth/verify-otp", "host": ["{{baseUrl}}"], "path": ["auth", "verify-otp"]},
						"body": {
							"mode": "raw",
							"raw": "{\n  \"phone\": \"{{testPhone}}\",\n  \"otp\": \"482910\"\n}"
						}
					},
					"event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
						"if (pm.response.code === 200) {",
						"    var json = pm.response.json();",
						"    pm.collectionVariables.set('accessToken', json.accessToken);",
						"    pm.collectionVariables.set('refreshToken', json.refreshToken);",
						"    pm.test('OTP verified', () => pm.expect(json.verified).to.be.true);",
						"}"
					]}}]
				},
				{
					"name": "Login (MPIN)",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"url": {"raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"]},
						"body": {
							"mode": "raw",
							"raw": "{\n  \"phone\": \"{{testPhone}}\",\n  \"pin\": \"{{testPin}}\"\n}"
						}
					},
					"event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
						"if (pm.response.code === 200) {",
						"    var json = pm.response.json();",
						"    pm.collectionVariables.set('accessToken', json.accessToken);",
						"    pm.collectionVariables.set('refreshToken', json.refreshToken);",
						"    pm.collectionVariables.set('userId', json.user.id);",
						"    pm.test('Login success', () => pm.expect(json.accessToken).to.not.be.empty);",
						"}"
					]}}]
				},
				{
					"name": "Login (Biometric)",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"url": {"raw": "{{baseUrl}}/auth/login/biometric", "host": ["{{baseUrl}}"], "path": ["auth", "login", "biometric"]},
						"body": {
							"mode": "raw",
							"raw": "{\n  \"userId\": \"{{userId}}\",\n  \"biometricToken\": \"device-signed-token\"\n}"
						}
					}
				},
				{
					"name": "Refresh Token",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"url": {"raw": "{{baseUrl}}/auth/refresh", "host": ["{{baseUrl}}"], "path": ["auth", "refresh"]},
						"body": {
							"mode": "raw",
							"raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
						}
					},
					"event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
						"if (pm.response.code === 200) {",
						"    var json = pm.response.json();",
						"    pm.collectionVariables.set('accessToken', json.accessToken);",
						"    pm.collectionVariables.set('refreshToken', json.refreshToken);",
						"}"
					]}}]
				},
				{
					"name": "Logout",
					"request": {
						"method": "POST",
						"header": [],
						"url": {"raw": "{{baseUrl}}/auth/logout", "host": ["{{baseUrl}}"], "path": ["auth", "logout"]}
					}
				}
			]
		},
		{
			"name": "02 — User Profile & KYC",
			"description": "User profile management and KYC Level 2 upgrade.",
			"item": [
				{
					"name": "Get My Profile",
					"request": {
						"method": "GET",
						"url": {"raw": "{{baseUrl}}/users/me", "host": ["{{baseUrl}}"], "path": ["users", "me"]}
					},
					"event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
						"pm.test('Profile loaded', () => {",
						"    pm.expect(pm.response.code).to.equal(200);",
						"    var json = pm.response.json();",
						"    pm.expect(json.phone).to.not.be.empty;",
						"    pm.expect(json.kycLevel).to.be.oneOf([1, 2]);",
						"});"
					]}}]
				},
				{
					"name": "Update My Profile",
					"request": {
						"method": "PUT",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"url": {"raw": "{{baseUrl}}/users/me", "host": ["{{baseUrl}}"], "path": ["users", "me"]},
						"body": {
							"mode": "raw",
							"raw": "{\n  \"firstName\": \"Abebe\",\n  \"lastName\": \"Girma\",\n  \"notificationsEnabled\": true\n}"
						}
					}
				},
				{
					"name": "Submit KYC Upgrade (multipart)",
					"request": {
						"method": "POST",
						"url": {"raw": "{{baseUrl}}/users/me/kyc/upgrade", "host": ["{{baseUrl}}"], "path": ["users", "me", "kyc", "upgrade"]},
						"body": {
							"mode": "formdata",
							"formdata": [
								{"key": "documentType", "value": "FAYDA_ID", "type": "text"},
								{"key": "documentFront", "type": "file", "src": ""},
								{"key": "documentBack", "type": "file", "src": ""},
								{"key": "selfieImage", "type": "file", "src": ""},
								{"key": "livenessToken", "value": "liveness-token-123", "type": "text"}
							]
						}
					}
				},
				{
					"name": "Get KYC Status",
					"request": {
						"method": "GET",
						"url": {"raw": "{{baseUrl}}/users/me/kyc/status", "host": ["{{baseUrl}}"], "path": ["users", "me", "kyc", "status"]}
					}
				}
			]
		},
		{
			"name": "03 — Wallet & Balance",
			"description": "Wallet balance and summary.",
			"item": [
				{
					"name": "Get Wallet Balance",
					"request": {
						"method": "GET",
						"url": {"raw": "{{baseUrl}}/wallet/balance", "host": ["{{baseUrl}}"], "path": ["wallet", "balance"]}
					},
					"event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
						"pm.test('Balance returned', () => {",
						"    var json = pm.response.json();",
						"    pm.expect(json.mainBalance).to.be.a('number');",
						"    pm.expect(json.currency).to.equal('ETB');",
						"});"
					]}}]
				},
				{
					"name": "Get Wallet Summary",
					"request": {
						"method": "GET",
						"url": {"raw": "{{baseUrl}}/wallet/summary", "host": ["{{baseUrl}}"], "path": ["wallet", "summary"]}
					}
				}
			]
		},
		{
			"name": "04 — P2P Transfers",
			"description": "Send money, request money, and contact management.",
			"item": [
				{
					"name": "Get Contacts",
					"request": {
						"method": "GET",
						"url": {"raw": "{{baseUrl}}/contacts", "host": ["{{baseUrl}}"], "path": ["contacts"]}
					}
				},
				{
					"name": "Lookup Contact by Phone",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"url": {"raw": "{{baseUrl}}/contacts/lookup", "host": ["{{baseUrl}}"], "path": ["contacts", "lookup"]},
						"body": {
							"mode": "raw",
							"raw": "{\n  \"phone\": \"+251922345678\"\n}"
						}
					}
				},
				{
					"name": "Send Money",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"url": {"raw": "{{baseUrl}}/transfers/send", "host": ["{{baseUrl}}"], "path": ["transfers", "send"]},
						"body": {
							"mode": "raw",
							"raw": "{\n  \"recipientPhone\": \"+251922345678\",\n  \"amount\": 250.00,\n  \"note\": \"For lunch\",\n  \"pin\": \"{{testPin}}\"\n}"
						}
					},
					"event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
						"pm.test('Transfer completed', () => {",
						"    pm.expect(pm.response.code).to.equal(201);",
						"    var json = pm.response.json();",
						"    pm.expect(json.status).to.equal('COMPLETED');",
						"    pm.expect(json.loyaltyPointsEarned).to.be.above(0);",
						"});"
					]}}]
				},
				{
					"name": "Request Money",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"url": {"raw": "{{baseUrl}}/transfers/request", "host": ["{{baseUrl}}"], "path": ["transfers", "request"]},
						"body": {
							"mode": "raw",
							"raw": "{\n  \"fromPhone\": \"+251922345678\",\n  \"amount\": 500.00,\n  \"note\": \"Split dinner bill\"\n}"
						}
					}
				},
				{
					"name": "List Money Requests",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/transfers/requests?direction=incoming&status=PENDING",
							"host": ["{{baseUrl}}"],
							"path": ["transfers", "requests"],
							"query": [
								{"key": "direction", "value": "incoming"},
								{"key": "status", "value": "PENDING"}
							]
						}
					}
				},
				{
					"name": "Accept/Decline Money Request",
					"request": {
						"method": "PUT",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"url": {"raw": "{{baseUrl}}/transfers/requests/{{requestId}}", "host": ["{{baseUrl}}"], "path": ["transfers", "requests", "{{requestId}}"]},
						"body": {
							"mode": "raw",
							"raw": "{\n  \"action\": \"ACCEPT\",\n  \"pin\": \"{{testPin}}\"\n}"
						}
					}
				}
			]
		},
		{
			"name": "05 — Bill Payments",
			"description": "Browse billers, validate accounts, and pay bills.",
			"item": [
				{
					"name": "List Billers",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/billers?category=telecom",
							"host": ["{{baseUrl}}"],
							"path": ["billers"],
							"query": [{"key": "category", "value": "telecom"}]
						}
					}
				},
				{
					"name": "Validate Biller Account",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"url": {"raw": "{{baseUrl}}/billers/{{billerId}}/validate", "host": ["{{baseUrl}}"], "path": ["billers", "{{billerId}}", "validate"]},
						"body": {
							"mode": "raw",
							"raw": "{\n  \"accountNumber\": \"0911234567\"\n}"
						}
					}
				},
				{
					"name": "Pay Bill",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"url": {"raw": "{{baseUrl}}/billers/{{billerId}}/pay", "host": ["{{baseUrl}}"], "path": ["billers", "{{billerId}}", "pay"]},
						"body": {
							"mode": "raw",
							"raw": "{\n  \"accountNumber\": \"0911234567\",\n  \"amount\": 350.00,\n  \"pin\": \"{{testPin}}\"\n}"
						}
					}
				}
			]
		},
		{
			"name": "06 — Airtime & Data",
			"description": "Telecom operators, bundles, and top-up.",
			"item": [
				{
					"name": "List Operators & Bundles",
					"request": {
						"method": "GET",
						"url": {"raw": "{{baseUrl}}/airtime/operators", "host": ["{{baseUrl}}"], "path": ["airtime", "operators"]}
					}
				},
				{
					"name": "Purchase Airtime/Data",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"url": {"raw": "{{baseUrl}}/airtime/topup", "host": ["{{baseUrl}}"], "path": ["airtime", "topup"]},
						"body": {
							"mode": "raw",
							"raw": "{\n  \"operatorId\": \"ethio-telecom\",\n  \"bundleId\": \"bundle-003\",\n  \"recipientPhone\": null,\n  \"isSelfTopup\": true,\n  \"pin\": \"{{testPin}}\"\n}"
						}
					}
				}
			]
		},
		{
			"name": "07 — Merchant Payments",
			"description": "Merchant directory, QR scan, and payment.",
			"item": [
				{
					"name": "Search Merchants",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/merchants?search=cafe&category=RESTAURANT",
							"host": ["{{baseUrl}}"],
							"path": ["merchants"],
							"query": [
								{"key": "search", "value": "cafe"},
								{"key": "category", "value": "RESTAURANT"}
							]
						}
					}
				},
				{
					"name": "Scan QR Code",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"url": {"raw": "{{baseUrl}}/merchants/scan", "host": ["{{baseUrl}}"], "path": ["merchants", "scan"]},
						"body": {
							"mode": "raw",
							"raw": "{\n  \"qrPayload\": \"globalpay://pay?merchant=MERCH-001\"\n}"
						}
					}
				},
				{
					"name": "Pay Merchant",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"url": {"raw": "{{baseUrl}}/merchants/{{merchantId}}/pay", "host": ["{{baseUrl}}"], "path": ["merchants", "{{merchantId}}", "pay"]},
						"body": {
							"mode": "raw",
							"raw": "{\n  \"amount\": 250.00,\n  \"pin\": \"{{testPin}}\"\n}"
						}
					}
				}
			]
		},
		{
			"name": "08 — Cash In / Cash Out",
			"description": "Agent-assisted cash operations.",
			"item": [
				{
					"name": "Find Nearby Agents",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/agents/nearby?lat=9.0192&lng=38.7525&radius=5",
							"host": ["{{baseUrl}}"],
							"path": ["agents", "nearby"],
							"query": [
								{"key": "lat", "value": "9.0192"},
								{"key": "lng", "value": "38.7525"},
								{"key": "radius", "value": "5"}
							]
						}
					}
				},
				{
					"name": "Initiate Cash In",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"url": {"raw": "{{baseUrl}}/cash/in", "host": ["{{baseUrl}}"], "path": ["cash", "in"]},
						"body": {
							"mode": "raw",
							"raw": "{\n  \"agentCode\": \"AGT-001\",\n  \"amount\": 2000.00,\n  \"pin\": \"{{testPin}}\"\n}"
						}
					}
				},
				{
					"name": "Initiate Cash Out",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"url": {"raw": "{{baseUrl}}/cash/out", "host": ["{{baseUrl}}"], "path": ["cash", "out"]},
						"body": {
							"mode": "raw",
							"raw": "{\n  \"agentCode\": \"AGT-001\",\n  \"amount\": 5000.00,\n  \"pin\": \"{{testPin}}\"\n}"
						}
					}
				}
			]
		},
		{
			"name": "09 — Savings Goals",
			"description": "Create, manage, deposit, and withdraw from savings goals.",
			"item": [
				{
					"name": "List Savings Goals",
					"request": {
						"method": "GET",
						"url": {"raw": "{{baseUrl}}/savings/goals", "host": ["{{baseUrl}}"], "path": ["savings", "goals"]}
					}
				},
				{
					"name": "Create Savings Goal",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"url": {"raw": "{{baseUrl}}/savings/goals", "host": ["{{baseUrl}}"], "path": ["savings", "goals"]},
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Vacation Fund\",\n  \"targetAmount\": 30000.00,\n  \"deadline\": \"2026-12-31\"\n}"
						}
					}
				},
				{
					"name": "Deposit into Goal",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"url": {"raw": "{{baseUrl}}/savings/goals/{{goalId}}/deposit", "host": ["{{baseUrl}}"], "path": ["savings", "goals", "{{goalId}}", "deposit"]},
						"body": {
							"mode": "raw",
							"raw": "{\n  \"amount\": 500.00,\n  \"pin\": \"{{testPin}}\"\n}"
						}
					}
				},
				{
					"name": "Withdraw from Goal",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"url": {"raw": "{{baseUrl}}/savings/goals/{{goalId}}/withdraw", "host": ["{{baseUrl}}"], "path": ["savings", "goals", "{{goalId}}", "withdraw"]},
						"body": {
							"mode": "raw",
							"raw": "{\n  \"amount\": 1000.00,\n  \"pin\": \"{{testPin}}\"\n}"
						}
					}
				}
			]
		},
		{
			"name": "10 — Micro-Loans",
			"description": "Loan eligibility, application, and repayment.",
			"item": [
				{
					"name": "Check Loan Eligibility",
					"request": {
						"method": "GET",
						"url": {"raw": "{{baseUrl}}/loans/eligibility", "host": ["{{baseUrl}}"], "path": ["loans", "eligibility"]}
					},
					"event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
						"pm.test('Eligibility returned', () => {",
						"    var json = pm.response.json();",
						"    pm.expect(json.aiCreditScore).to.be.within(0, 100);",
						"});"
					]}}]
				},
				{
					"name": "Get Repayment Plans",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/loans/plans?amount=3000",
							"host": ["{{baseUrl}}"],
							"path": ["loans", "plans"],
							"query": [{"key": "amount", "value": "3000"}]
						}
					}
				},
				{
					"name": "Apply for Loan",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"url": {"raw": "{{baseUrl}}/loans/apply", "host": ["{{baseUrl}}"], "path": ["loans", "apply"]},
						"body": {
							"mode": "raw",
							"raw": "{\n  \"amount\": 3000.00,\n  \"termMonths\": 3,\n  \"purpose\": \"Business inventory\",\n  \"pin\": \"{{testPin}}\"\n}"
						}
					}
				},
				{
					"name": "Get Active Loans",
					"request": {
						"method": "GET",
						"url": {"raw": "{{baseUrl}}/loans/active", "host": ["{{baseUrl}}"], "path": ["loans", "active"]}
					}
				},
				{
					"name": "Repay Loan",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"url": {"raw": "{{baseUrl}}/loans/{{loanId}}/repay", "host": ["{{baseUrl}}"], "path": ["loans", "{{loanId}}", "repay"]},
						"body": {
							"mode": "raw",
							"raw": "{\n  \"amount\": 1050.00,\n  \"pin\": \"{{testPin}}\"\n}"
						}
					}
				}
			]

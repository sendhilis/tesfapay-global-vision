# ─── GlobalPay Microservices — Environment Variables ───────────────
# Copy this to .env and fill in production values before deploying.

# ── Database ──────────────────────────────────────────────────────
DB_PASSWORD=devpass
DB_USERNAME=globalpay

# ── JWT (MUST be changed in production — min 32 chars) ────────────
JWT_SECRET=SuperSecretKeyForGlobalPayJWT2024MustBe256BitsLongEnough!

# ── Redis ─────────────────────────────────────────────────────────
REDIS_PASSWORD=RedisPass123!

# ── Eureka Service Discovery ───────────────────────────────────────
EUREKA_USERNAME=eureka
EUREKA_PASSWORD=EurekaPass123!
EUREKA_CLIENT_SERVICEURL_DEFAULTZONE=http://eureka:EurekaPass123!@gp-discovery:8761/eureka/

# ── MinIO (KYC document storage) ─────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_URL=http://minio:9000
MINIO_BUCKET_KYC=kyc-documents

# ── Kafka ─────────────────────────────────────────────────────────
SPRING_KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# ── OTP (set false in production to use real SMS) ─────────────────
OTP_MOCK_ENABLED=true

# ── SMS Provider (Africa's Talking or Twilio) ─────────────────────
# AT_API_KEY=your_africas_talking_api_key
# AT_USERNAME=your_africas_talking_username
# TWILIO_ACCOUNT_SID=your_twilio_account_sid
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_PHONE_NUMBER=+1234567890

# ── Frontend CORS origins ─────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,https://tesfapay-global-vision.lovable.app,capacitor://localhost

# ── GlobalPay Microservices —- Environment Variables ───
# Copy this to .env and fill in production values before deploying.

# │─ Database ─────────────────────────────────
DB_PASSWORD=devpass
DB_USERNAME=globalpay

# │─ JWT (MUST be changed in production ─ min 32 chars) ────────
JWT_SECRET=SuperSecretKeyForGlobalPayJWT2024MustBe256BitsLongEnough!

# │─ Redis ───────────────────────────────────
REDIS_PASSWORD=RedisPass123!

# │─ Eureka Service Discovery  ─────────────────────
EUREKA_USERNAME=eureka
EUREKA_PASSWORD=EurekaPass123!
EUREKA_CLIENT_SERVICEURL_DEFAULTZONE=http://eureka:EurekaPass123!@gp-discovery:8761/eureka/

# │─ MinIO (KYC document storage) ──────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=miniopassword
MINIO_ENDPOINT=http://minio:9000

# │─ Africa's Talking (SMS)  ────────────────
AT_API_KEY=sandbox
AT_USERNAME=sandbox
AT_SMS_SHORTCODE=12345
OTP_MOCK_ENABLED=true

# │─ NBE / Fayda ID (KYC) ─────────────────────
FAYDA_API_URL=https://api.fayda.et/v1
FAYDA_API_KEY=dev_fayda_key_replace_in_prod

# │─ Firebase (Push Notifications) ────────────────
FIREBASE_PROJECT_ID=tesfapay
FCM_SERVER_KEY=replace_with_real_fcm_key

# │─ Security (Change all in production!) ───────────
SPRING_SECURITY_USER_NAME=admin
SPRING_SECURITY_USER_PASSWORD=admin123
